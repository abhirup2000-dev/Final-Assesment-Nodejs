<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>
    <%= title %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

  <style>
    :root {
      --bg-deep: #07090f;
      --bg-card: rgba(255, 255, 255, 0.05);
      --bg-soft: rgba(255, 255, 255, 0.04);
      --border: rgba(255, 255, 255, 0.08);
      --border-hi: rgba(255, 255, 255, 0.16);
      --accent: #6366f1;
      --accent-2: #8b5cf6;
      --text-hi: #f1f5f9;
      --text-mid: #94a3b8;
      --text-lo: #64748b;
    }

    body {
      background: radial-gradient(circle at 20% 20%, #1e1b4b, #020617);
      color: var(--text-hi);
      font-family: "Inter", sans-serif;
      margin: 0;
      min-height: 100vh;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 0;
    }

    body::before {
      width: 400px;
      height: 400px;
      background: rgba(99, 102, 241, 0.25);
      top: -100px;
      right: -100px;
    }

    body::after {
      width: 300px;
      height: 300px;
      background: rgba(139, 92, 246, 0.25);
      bottom: -100px;
      left: -100px;
    }

    .container {
      margin-top: 60px;
      margin-bottom: 60px;
      max-width: 950px;
      position: relative;
      z-index: 1;
    }

    .profile-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 26px;
      margin-bottom: 24px;
      backdrop-filter: blur(20px);
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
      transition: 0.25s;
    }

    .profile-card:hover {
      border-color: var(--border-hi);
    }

    .avatar {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      margin: 0 auto 14px;
      box-shadow: 0 12px 30px rgba(99, 102, 241, 0.5);
      overflow: hidden;
    }

    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .name {
      font-size: 1.4rem;
      font-weight: 700;
    }

    .role {
      font-size: 0.82rem;
      color: var(--text-mid);
    }

    .info-box {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
      transition: 0.25s;
    }

    .info-box:hover {
      background: rgba(255, 255, 255, 0.08);
      transform: translateY(-3px);
      border-color: var(--border-hi);
    }

    .info-label {
      font-size: 0.72rem;
      color: var(--text-mid);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .info-value {
      font-size: 0.95rem;
      font-weight: 600;
      word-break: break-word;
    }

    .form-control {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border-hi);
      border-radius: 12px;
      padding: 12px;
      color: #fff !important;
      -webkit-text-fill-color: #fff !important;
      caret-color: #fff;
      transition: 0.2s;
    }

    .form-control:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25);
      background: rgba(255, 255, 255, 0.08);
    }

    input:-webkit-autofill,
    input:-webkit-autofill:focus {
      -webkit-text-fill-color: #fff !important;
      box-shadow: 0 0 0px 1000px rgba(255, 255, 255, 0.05) inset !important;
    }

    label {
      font-size: 0.75rem;
      color: var(--text-mid);
      margin-bottom: 6px;
    }

    .btn-save {
      width: 100%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      border: none;
      padding: 12px;
      border-radius: 12px;
      color: #fff;
      font-weight: 600;
      transition: 0.25s;
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    }

    .btn-save:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 35px rgba(99, 102, 241, 0.5);
    }

    h6 {
      font-weight: 600;
      margin-bottom: 14px;
    }

    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      max-width: 320px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      animation: slideIn 0.3s ease;
    }

    .alert-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    .alert-close {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      opacity: 0.7;
    }

    .alert-close:hover {
      opacity: 1;
    }

    .alert-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 100%;
      background: currentColor;
      opacity: 0.4;
      animation: shrink 4s linear forwards;
    }

    .profile-preview {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes shrink {
      from {
        width: 100%;
      }

      to {
        width: 0%;
      }
    }
  </style>
</head>

<body>

  <!-- ALERTS -->
  <div class="alert-container">

    <% if (typeof error !=="undefined" && error.length> 0) { %>
      <div class="custom-alert error">
        <div class="alert-left">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span>
            <%= error[0] %>
          </span>
        </div>

        <button class="alert-close" onclick="dismissAlert(this)">
          <i class="bi bi-x-lg"></i>
        </button>

        <div class="alert-bar"></div>
      </div>
      <% } %>

        <% if (typeof success !=="undefined" && success.length> 0) { %>
          <div class="custom-alert success">
            <div class="alert-left">
              <i class="bi bi-check-circle-fill"></i>
              <span>
                <%= success[0] %>
              </span>
            </div>

            <button class="alert-close" onclick="dismissAlert(this)">
              <i class="bi bi-x-lg"></i>
            </button>

            <div class="alert-bar"></div>
          </div>
          <% } %>

  </div>

  <div class="container">

    <!-- PROFILE HEADER -->
    <div class="profile-card text-center">

      <div class="avatar">

        <% if(admin.profileImage) { %>

          <img src="<%= admin.profileImage %>" alt="Profile">

          <% } else { %>

            <i class="bi bi-person"></i>

            <% } %>

      </div>

      <div class="name">
        <%= admin.adminName %>
      </div>

      <div class="role">
        Administrator
      </div>

    </div>

    <!-- ACCOUNT DETAILS -->
    <div class="profile-card">

      <h6 class="mb-3">Account Overview</h6>

      <div class="row g-3">

        <div class="col-md-6">
          <div class="info-box">
            <div class="info-label">Full Name</div>
            <div class="info-value">
              <%= admin.adminName %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-box">
            <div class="info-label">Email</div>
            <div class="info-value">
              <%= admin.email %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-box">
            <div class="info-label">Admin ID</div>
            <div class="info-value">
              <%= admin._id %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-box">
            <div class="info-label">Joined</div>
            <div class="info-value">
              <%= new Date(admin.createdAt).toLocaleDateString() %>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- PROFILE IMAGE UPDATE -->
    <div class="profile-card">

      <h6 class="mb-3">Update Profile Picture</h6>

      <div class="text-center mb-4">

        <% if(admin.profileImage) { %>

          <img src="<%= admin.profileImage %>" class="profile-preview" id="preview" />

          <% } else { %>

            <img id="preview" class="profile-preview d-none" />

            <% } %>

      </div>

      <form action="/admin/update/profile-image" method="POST" enctype="multipart/form-data">

        <div class="mb-3">
          <label>Select Image</label>

          <input type="file" name="profileImage" class="form-control" accept="image/*" onchange="previewImage(event)"
            required />
        </div>

        <button class="btn-save">
          Update Profile Picture
        </button>

      </form>

    </div>

    <!-- PASSWORD UPDATE -->
    <div class="profile-card">

      <h6 class="mb-3">Change Password</h6>

      <form action="/admin/password-update" method="POST">

        <div class="mb-3">
          <label>Current Password</label>

          <input type="password" name="currentPassword" class="form-control" required />
        </div>

        <div class="mb-3">
          <label>New Password</label>

          <input type="password" name="newPassword" class="form-control" required />
        </div>

        <button class="btn-save">
          Update Password
        </button>

      </form>

    </div>

  </div>

  <script>

    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");

      el.style.opacity = "0";
      el.style.transform = "translateX(40px)";

      setTimeout(() => {
        el.remove();
      }, 250);
    }

    setTimeout(() => {

      document.querySelectorAll(".custom-alert").forEach(el => {

        el.style.opacity = "0";
        el.style.transform = "translateX(40px)";

        setTimeout(() => {
          el.remove();
        }, 250);

      });

    }, 4000);

    function previewImage(event) {

      const file = event.target.files[0];

      if (!file) return;

      const reader = new FileReader();

      reader.onload = function (e) {

        const preview = document.getElementById("preview");

        preview.src = e.target.result;

        preview.classList.remove("d-none");
      };

      reader.readAsDataURL(file);
    }

  </script>

</body>

</html>