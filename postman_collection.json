                  "mode": "formdata",
                  "formdata": [
                    { "key": "userName", "value": "testuser", "type": "text" },
                    { "key": "email", "value": "user@example.com", "type": "text" },
                    { "key": "password", "value": "password123", "type": "text" },
                    { "key": "profileImage", "type": "file", "src": [] }
